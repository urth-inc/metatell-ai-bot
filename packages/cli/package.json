{
  "name": "@metatell/bot-cli",
  "version": "1.0.0",
  "description": "CLI tool for Metatell bot development and testing",
  "type": "module",
  "bin": {
    "metatell-bot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@metatell/bot-sdk": "workspace:*",
    "commander": "12.0.0",
    "ink": "5.0.1",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "22.17.2",
    "@types/react": "18.3.12",
    "tsx": "4.20.5",
    "typescript": "5.6.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/urth-inc/metatell-ai-bot",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
