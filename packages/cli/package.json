{
  "name": "@metatell/bot-cli",
  "version": "0.0.11",
  "description": "CLI tool for Metatell bot development and testing",
  "type": "module",
  "bin": {
    "metatell-bot": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@metatell/bot-sdk": "workspace:*",
    "commander": "12.1.0",
    "ink": "6.5.0",
    "react": "19.1.1"
  },
  "devDependencies": {
    "@types/node": "22.19.1",
    "@types/react": "19.1.13",
    "tsx": "4.21.0",
    "typescript": "5.9.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/urth-inc/metatell-ai-bot",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
