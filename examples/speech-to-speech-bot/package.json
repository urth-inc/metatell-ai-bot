{
  "name": "speech-to-speech-bot",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "tsx --env-file=.env src/main.ts",
    "dev": "tsx watch --env-file=.env src/main.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/speech": "^6.7.0",
    "@google-cloud/text-to-speech": "^5.5.0",
    "@google/genai": "^1.19.0",
    "@metatell/bot-realtime": "^0.0.10",
    "@metatell/bot-sdk": "^0.0.10",
    "dotenv": "^16.3.1",
    "webrtcvad": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2"
  }
}
