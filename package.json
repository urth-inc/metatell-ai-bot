{
  "name": "metatell-ai-bot",
  "version": "1.0.0",
  "description": "Phoenix Channel client for connecting to Metatell metaverse",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "npm run build && node dist/main.js",
    "bot": "npm run build && node dist/main.js",
    "bot:room": "npm run build && node dist/main.js https://metatell.app/LWF5w8n/",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "metatell",
    "phoenix",
    "websocket",
    "metaverse",
    "bot",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.0",
    "ink": "^6.1.0",
    "ink-gradient": "^3.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "phoenix": "^1.7.7",
    "react": "^19.1.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.10.0",
    "@types/phoenix": "^1.6.4",
    "@types/react": "^19.1.9",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "happy-dom": "^18.0.1",
    "typescript": "^5.3.2",
    "vitest": "^3.2.4"
  }
}
