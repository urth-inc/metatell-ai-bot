{
  "name": "metatell-ai-bot",
  "version": "0.0.10",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:ui": "vitest run --ui --coverage",
    "test:coverage": "vitest run --coverage",
    "check": "biome check --error-on-warnings",
    "check:fix": "biome check --error-on-warnings --write",
    "typecheck": "tsc --build",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "bumpup": "changeset version",
    "release": "pnpm build && changeset publish",
    "typedoc": "typedoc"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@changesets/cli": "2.29.7",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.1",
    "@types/phoenix": "1.6.6",
    "@types/react": "19.1.13",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "happy-dom": "18.0.1",
    "lefthook": "1.13.6",
    "typedoc": "0.28.12",
    "typedoc-plugin-missing-exports": "4.1.0",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/urth-inc/metatell-ai-bot"
  },
  "volta": {
    "node": "22.21.1"
  },
  "packageManager": "pnpm@10.22.0"
}
