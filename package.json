{
  "name": "metatell-ai-bot",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @metatell/bot-core && npm run build -w @metatell/bot-sdk && npm run build -w @metatell/bot-realtime",
    "build:all": "npm run build --workspaces",
    "test": "vitest run",
    "test:ui": "vitest run --ui --coverage",
    "test:coverage": "vitest run --coverage",
    "check": "biome check --error-on-warnings",
    "check:fix": "biome check --error-on-warnings --write",
    "typecheck": "tsc --build",
    "clean": "npm run clean --workspaces"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.17.2",
    "@types/phoenix": "1.6.6",
    "@types/react": "19.1.11",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "happy-dom": "18.0.1",
    "lefthook": "1.12.3",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  },
  "license": "MIT",
  "volta": {
    "node": "22.18.0",
    "npm": "11.5.2"
  }
}
