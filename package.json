{
  "name": "metatell-ai-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @metatell/sdk && npm run build -w @metatell/bot",
    "build:all": "npm run build --workspaces",
    "test": "vitest",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest --coverage",
    "check": "biome check --error-on-warnings .",
    "check:fix": "biome check --error-on-warnings --write .",
    "typecheck": "tsc --build",
    "dev": "npm run dev -w @metatell/bot",
    "start": "npm run start -w @metatell/bot",
    "clean": "npm run clean --workspaces"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@testing-library/jest-dom": "6.8.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.17.2",
    "@types/phoenix": "1.6.6",
    "@types/react": "19.1.10",
    "@types/ws": "8.18.1",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "3.2.4",
    "happy-dom": "18.0.1",
    "lefthook": "^1.12.3",
    "typescript": "5.9.2",
    "vitest": "3.2.4"
  },
  "license": "MIT"
}
