{
  "name": "metatell-ai-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest",
    "test:ui": "vitest --ui --coverage",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --build",
    "dev": "npm run dev -w @metatell/bot",
    "start": "npm run start -w @metatell/bot",
    "clean": "npm run clean --workspaces"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.10.0",
    "@types/phoenix": "^1.6.4",
    "@types/react": "^19.1.9",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "happy-dom": "^18.0.1",
    "typescript": "^5.3.2",
    "vitest": "^3.2.4"
  },
  "license": "MIT"
}